# OCR_server runtime env — copy thành OCR_server/.env rồi điền giá trị thật.
# Container đọc file này qua docker-compose `env_file:`.

# ── Storage ──────────────────────────────────────────────────────────────
# Trong container path luôn là /app/OCR_server/data/ocr_storage (mount volume).
# Compose override env này, không cần đổi cho Docker. Cho non-Docker thì set host path.
STORAGE_PATH=/app/OCR_server/data/ocr_storage

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
OCR_API_KEY=REPLACE_WITH_64_HEX_KEY

# ── Limits ───────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT=300/minute

# ── VLM (Qwen2.5-VL-3B qua vLLM) ─────────────────────────────────────────
# Compose override sang http://host.docker.internal:8080/... (xem docker-compose.yml).
# Cho bare-metal dev: localhost:8080.
VLM_ENDPOINT=http://localhost:8080/v1/chat/completions
VLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
VLM_TIMEOUT_SECONDS=120
