# Top-level .env — đọc bởi docker compose (KHÁC OCR_server/.env, là env của app).
# Copy: cp .env.example .env  rồi điền secret thật.

# ── ngrok ────────────────────────────────────────────────────────────────
# Lấy từ https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ── Telegram monitor ─────────────────────────────────────────────────────
# Bot từ @BotFather, chat_id từ @userinfobot
TG_BOT_TOKEN=
TG_CHAT_ID=

# Label hiển thị trong alert (mặc định: ocr-docker)
HOST_LABEL=ocr-prod
